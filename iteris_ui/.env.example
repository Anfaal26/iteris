# --------------------------------------------------------------------------
# Iteris UI environment template. Copy to `.env` / `.env.local` and fill in.
# NO secret or host is ever hardcoded in the bundle — everything comes from here.
# Only VITE_-prefixed vars are exposed to the client (Vite convention).
# --------------------------------------------------------------------------

# Base URL the frontend uses to reach the FastAPI backend.
# Leave as "/api" to use the dev-server proxy (see VITE_API_PROXY_TARGET).
VITE_API_BASE_URL=/api

# Dev-only: where the /api proxy forwards to (the running FastAPI backend).
VITE_API_PROXY_TARGET=http://localhost:8000

# When "true", the UI serves bundled mock data instead of calling the backend.
# Lets the UI run standalone (e.g. HF Spaces preview) before ML endpoints exist.
VITE_USE_MOCKS=true
