# --------------------------------------------------------------------------
# Iteris UI environment template. Copy to `.env` / `.env.local` and fill in.
# NO secret or host is ever hardcoded in the bundle — everything comes from here.
# Only VITE_-prefixed vars are exposed to the client (Vite convention).
# --------------------------------------------------------------------------

# Base URL the frontend uses to reach the FastAPI backend.
# Leave as "/api" to use the dev-server proxy (see VITE_API_PROXY_TARGET).
VITE_API_BASE_URL=/api

# Dev-only: where the /api proxy forwards to (the running FastAPI backend).
VITE_API_PROXY_TARGET=http://localhost:8000

# When "true", the UI serves bundled mock data instead of calling the backend.
# Lets the UI run standalone (e.g. HF Spaces preview) before ML endpoints exist.
VITE_USE_MOCKS=true

# --------------------------------------------------------------------------
# SERVER-SIDE ONLY (no VITE_ prefix ⇒ never bundled into client code).
# These are read by the Vercel serverless functions in iteris_ui/api/*.ts and
# must be set in the Vercel project's Environment Variables, not committed.
# --------------------------------------------------------------------------

# api/infer.ts — the HF Space serving DRL inference.
ITERIS_SPACE_URL=https://<your-space>.hf.space
# Optional; only if the Space is ever locked down.
ITERIS_SPACE_TOKEN=

# api/chat.ts — Groq free-tier key for the workspace chat (console.groq.com/keys).
GROQ_API_KEY=
# Optional override. Defaults to llama-3.3-70b-versatile;
# use llama-3.1-8b-instant if latency matters more than answer depth.
GROQ_MODEL=llama-3.3-70b-versatile
